
/dts-v1/;
/ {
    overlay-name = "Boot Priority Settings";
    fragment@0 {
        target-path = "/";
        board_config { sw-modules = "uefi"; };
        __overlay__ {
            firmware {
                uefi {
                    variables {
                        gNVIDIAPublicVariableGuid {
                            /* Valid tokens include: sd, nvme, usb, emmc, sata, http, pxe, shell */
                            DefaultBootPriority {
                                /* Put SD first, then NVMe, then USB, then HTTP/PXE */
                                /* Finding H5: internal storage only. usb/http/pxe
                                 * are deliberately excluded so an attacker with
                                 * physical access (USB stick) or on the LAN (rogue
                                 * DHCP/HTTP/PXE) cannot boot arbitrary code ahead of
                                 * internal media. Recovery flashing uses Tegra
                                 * recovery mode, not the UEFI boot order. */
                                data = "sd, nvme";
                                locked;
                            };
                        };
                    };
                };
            };
        };
    };
};
