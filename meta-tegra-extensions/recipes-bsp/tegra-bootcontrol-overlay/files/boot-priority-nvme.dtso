
/dts-v1/;
/ {
    overlay-name = "Boot Priority Settings (NVMe first)";
    fragment@0 {
        target-path = "/";
        board_config { sw-modules = "uefi"; };
        __overlay__ {
            firmware {
                uefi {
                    variables {
                        gNVIDIAPublicVariableGuid {
                            /* Valid tokens include: sd, nvme, usb, emmc, sata, http, pxe, shell */
                            DefaultBootPriority {
                                /* NVMe first so wendy os install works out of the box.
                                   Local storage only; USB/HTTP/PXE removed so the device
                                   cannot boot attacker media or a network image (H5,
                                   compounds C2). Recovery via NVIDIA recovery mode. */
                                data = "nvme, sd";
                                locked;
                            };
                        };
                    };
                };
            };
        };
    };
};
